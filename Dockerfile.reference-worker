# Reference corpus expansion worker — synthetic + OSSF eval only (no weaponization).
FROM node:22-bookworm-slim

RUN apt-get update \
  && apt-get install -y --no-install-recommends git ca-certificates \
  && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY package.json package-lock.json* ./
RUN npm ci 2>/dev/null || npm install

COPY tsconfig.json ./
COPY scripts ./scripts
COPY eval ./eval

ENV NODE_ENV=production
ENV REFERENCE_DATA_DIR=/data/corpus
ENV CWE_MIRROR_URL=https://cwe.klaut.pro

RUN chmod +x scripts/worker/*.sh

VOLUME ["/data/corpus"]

CMD ["/app/scripts/worker/run-expansion-cycle.sh"]
