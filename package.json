{
  "name": "li-sec-agent",
  "version": "0.1.0",
  "private": true,
  "description": "AI security agent for PR reviews — on-cluster Qwen, findings capture",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "eval:models": "tsx scripts/eval-models.ts",
    "benchmark:generate": "tsx scripts/benchmarks/generate-multilang-corpus.ts",
    "benchmark:cwe-inventory": "tsx scripts/benchmarks/cwe-inventory.ts",
    "benchmark:cwe-enrich": "tsx scripts/benchmarks/cwe-enrich-mitre.ts",
    "benchmark:cwe-scenarios": "tsx scripts/benchmarks/generate-cwe-scenarios.ts",
    "benchmark:build-cwe-db": "tsx scripts/benchmarks/cwe-inventory.ts --write-snapshot && tsx scripts/benchmarks/cwe-enrich-mitre.ts && tsx scripts/benchmarks/generate-cwe-scenarios.ts",
    "benchmark:fetch-ossf": "tsx scripts/benchmarks/fetch-ossf-cve-subset.ts",
    "benchmark:expand-reference": "tsx scripts/benchmarks/expand-reference-corpus.ts",
    "benchmark:build-reference-db": "tsx scripts/benchmarks/build-reference-db.ts",
    "benchmark:reference-v1": "tsx scripts/benchmarks/fetch-ossf-cve-subset.ts && tsx scripts/benchmarks/expand-reference-corpus.ts && tsx scripts/benchmarks/build-reference-db.ts",
    "export:finetune-jsonl": "tsx scripts/export-finetune-jsonl.ts",
    "test": "node --import tsx --test src/**/*.test.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.13.4",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3"
  }
}
