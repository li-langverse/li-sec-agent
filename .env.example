# Local / worker runtime (never commit real values)

# HTTP server
PORT=8787
HOST=0.0.0.0

# In-cluster Qwen (Ollama OpenAI-compatible API)
QWEN_BASE_URL=http://qwen-ollama.secagent-staging.svc.cluster.local:11434/v1
QWEN_MODEL=qwen2.5-coder:3b
QWEN_API_KEY=ollama

# Data layer (MVP: SQLite file; staging/prod: Postgres)
DATABASE_URL=sqlite:./data/secagent.db
# DATABASE_URL=postgresql://secagent:REPLACE@postgres.secagent-staging:5432/secagent

# GitHub App (install on org/repos — placeholders)
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_PATH=
GITHUB_WEBHOOK_SECRET=

# Optional: static analysis tools (future)
SEMGREP_ENABLED=false

# Telemetry & billing context
SECAGENT_ORG_ID=homelab
SECAGENT_TIER=free
GITHUB_APP_INSTALLATION_ID=

# OpenTelemetry (optional)
OTEL_SERVICE_NAME=li-sec-agent
OTEL_EXPORTER_OTLP_ENDPOINT=
